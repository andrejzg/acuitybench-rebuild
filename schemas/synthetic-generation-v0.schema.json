{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:acuitybench:schema:synthetic-generation:v0",
  "title": "Fictional static-acuity generation v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "vignette",
    "intended_acuity",
    "presentation_group",
    "age_years",
    "sex_context",
    "relevant_facts",
    "distractor_facts",
    "intended_rationale",
    "fictional_attestation"
  ],
  "properties": {
    "schema_version": {"const": "synthetic-acuity-generation/v0"},
    "vignette": {"type": "string", "minLength": 80, "maxLength": 6000, "pattern": "\\S"},
    "intended_acuity": {"type": "string", "enum": ["A", "B", "C", "D"]},
    "presentation_group": {
      "type": "string",
      "enum": [
        "infection_systemic",
        "cardiopulmonary",
        "abdominal_urinary",
        "neurologic",
        "skin_musculoskeletal"
      ]
    },
    "age_years": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 110
    },
    "sex_context": {"type": "string", "minLength": 2, "maxLength": 200, "pattern": "\\S"},
    "relevant_facts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {"type": "string", "minLength": 2, "maxLength": 1000, "pattern": "\\S"}
    },
    "distractor_facts": {
      "type": "array",
      "maxItems": 8,
      "items": {"type": "string", "minLength": 2, "maxLength": 1000, "pattern": "\\S"}
    },
    "intended_rationale": {"type": "string", "minLength": 10, "maxLength": 3000, "pattern": "\\S"},
    "fictional_attestation": {
      "const": "Entirely fictional; no real person or source case was used."
    }
  }
}
